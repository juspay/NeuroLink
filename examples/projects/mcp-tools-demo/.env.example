# NeuroLink MCP Tools Demo - Environment Variables

# Required: At least one AI provider API key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: For external MCP server demos
GITHUB_TOKEN=your-github-personal-access-token

# Optional: For PostgreSQL MCP server demo
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/database

# Optional: For remote HTTP MCP servers
MCP_SERVER_AUTH_TOKEN=your-mcp-server-auth-token
