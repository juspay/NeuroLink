{
  "mcpServers": {
    "filesystem": {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "transport": "stdio"
    }
  },
  "autoDiscovery": {
    "enabled": true,
    "autoRegister": true
  },
  "defaultRegistry": {
    "enabled": true,
    "includeBuiltInTools": true
  }
}
