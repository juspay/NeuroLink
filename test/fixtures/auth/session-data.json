  "sessionScenarios": {
    "createSession": {
      "input": {
        "userId": "user_new_001",
        "email": "newuser@test.neurolink.dev",
        "name": "New Session User",
        "roles": ["user"],
        "permissions": ["read:public"]
      },
      "expectedOutput": {
        "hasId": true,
        "isValid": true,
        "hasAccessToken": true,
        "expiresInFuture": true
      }
    },

    "refreshSession": {
      "input": {
        "sessionId": "sess_valid_001",
        "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test-valid-session-refresh-token"
      },
      "expectedOutput": {
        "success": true,
        "newAccessToken": true,
        "extendedExpiry": true
      }
    },

    "validateSession": {
      "validInput": {
        "sessionId": "sess_valid_001"
      },
      "expiredInput": {
        "sessionId": "sess_expired_001"
      },
      "invalidInput": {
        "sessionId": "sess_nonexistent_999"
      }
    },

    "revokeSession": {
      "input": {
        "sessionId": "sess_valid_001"
      },
      "expectedOutput": {
        "success": true,
        "sessionInvalidated": true
      }
    },

    "revokeAllUserSessions": {
      "input": {
        "userId": "user_multi_001"
      },
      "expectedOutput": {
        "success": true,
        "sessionsRevoked": 2
      }
    }
  },

