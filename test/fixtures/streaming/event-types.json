      "description": "Text with tool call and result",
      "events": [
        "message:start",
        "text:start",
        "text:delta",
        "text:end",
        "tool:call:start",
        "tool:call",
        "tool:execute:start",
        "tool:result",
        "text:start",
        "text:delta",
        "text:end",
        "message:end"
      ]
    },
    "reasoningWithText": {
      "description": "Extended thinking followed by text response",
      "events": [
        "message:start",
        "reasoning:start",
        "reasoning:delta",
        "reasoning:delta",
        "reasoning:end",
        "text:start",
        "text:delta",
        "text:end",
        "message:end"
