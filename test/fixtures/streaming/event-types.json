  "typeGuards": {
    "isTextEvent": ["text:start", "text:delta", "text:end"],
    "isToolEvent": [
      "tool:call:start",
      "tool:call:delta",
      "tool:call",
      "tool:execute:start",
      "tool:result"
    ],
    "isReasoningEvent": ["reasoning:start", "reasoning:delta", "reasoning:end"],
    "isMessageEvent": ["message:start", "message:end"],
    "isObjectEvent": ["object:delta", "object:complete"],
    "isStepEvent": ["step:start", "step:end"],
    "isAudioEvent": ["audio:start", "audio:delta", "audio:end"],
    "isErrorEvent": ["error"],
    "isContentEvent": [
      "text:delta",
      "reasoning:delta",
      "tool:call:delta",
      "audio:delta",
      "object:delta"
    ],
    "isStartEvent": [
      "text:start",
      "reasoning:start",
      "tool:call:start",
      "tool:execute:start",
      "message:start",
      "step:start",
      "audio:start"
